modules = ["web", "nodejs-20", "python-3.11", "postgresql-16"]
run = "npx serve ."

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[deployment]
run = ["bash", "-c", "PORT=3000 python3 server.py"]
deploymentTarget = "autoscale"
build = ["pip", "install", "-r", "requirements.txt"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server.py"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "ventas@crbox.cr"
MYSQL_HOST = "crboxdbserver.cvfe6dzk8nhz.us-east-1.rds.amazonaws.com"
MYSQL_PORT = "3306"
MYSQL_DATABASE = "crbox_dev1"
MYSQL_USER = "CrBoxUser"
USE_RDS_PORTAL_API = "true"

[userenv.development]
USE_RDS_INVOICES_FRONTEND = "true"
USE_RDS_PROFILE_FRONTEND = "true"
EXPECTED_RDS_DATABASE = "crbox_dev1"
USE_RDS_PACKAGES_FRONTEND = "true"

[userenv.production]
RDS_PORTAL_HOST = "crboxdbserver.cvfe6dzk8nhz.us-east-1.rds.amazonaws.com"
RDS_PORTAL_PORT = "3306"
RDS_PORTAL_DATABASE = "CrBox"
RDS_PORTAL_USER = "crbox_portal_ro"
EXPECTED_RDS_DATABASE = "CrBox"
ALLOWED_ORIGIN = "https://crbox.cr,https://www.crbox.cr,https://crbox-web.replit.app"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3002
