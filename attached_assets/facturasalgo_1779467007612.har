\">HERRAMIENTA MANUAL</option>\r\n                                <option value=\"HERRAMIENTAS ELECTRICAS\" label=\"HERRAMIENTAS ELECTRICAS\">HERRAMIENTAS ELECTRICAS</option>\r\n                                <option value=\"HERRAMIENTAS NEUMATICAS\" label=\"HERRAMIENTAS NEUMATICAS\">HERRAMIENTAS NEUMATICAS</option>\r\n                                <option value=\"IMPRESORAS\" label=\"IMPRESORAS\">IMPRESORAS</option>\r\n                                <option value=\"JUGUETES\" label=\"JUGUETES\">JUGUETES</option>\r\n                                <option value=\"LAMPARA\" label=\"LAMPARA\">LAMPARA</option>\r\n                                <option value=\"LAPTOP\" label=\"LAPTOP\">LAPTOP</option>\r\n                                <option value=\"LLANTAS\" label=\"LLANTAS\">LLANTAS</option>\r\n                                <option value=\"LIBROS\" label=\"LIBROS\">LIBROS</option>\r\n                                <option value=\"MATERIAL PUBLICITARIO\" label=\"MATERIAL PUBLICITARIO\">MATERIAL PUBLICITARIO</option>\r\n                                <option value=\"MALETIN\" label=\"MALETIN\">MALETIN</option>\r\n                                <option value=\"MEMORIA\" label=\"MEMORIA\">MEMORIA</option>\r\n                                <option value=\"MOLDES\" label=\"MOLDES\">MOLDES</option>\r\n                                <option value=\"MONITORES\" label=\"MONITORES\">MONITORES</option>\r\n                                <option value=\"MUEBLES\" label=\"MUEBLES\">MUEBLES</option>\r\n                                <option value=\"NAVAJA\" label=\"NAVAJA\">NAVAJA</option>\r\n                                <option value=\"TABLETAS\" label=\"TABLETAS\">TABLETAS</option>\r\n                                <option value=\"PARTES PARA BICICLETA\" label=\"PARTES PARA BICICLETA\">PARTES PARA BICICLETA</option>\r\n                                <option value=\"PARTES PARA IMPRESORA\" label=\"PARTES PARA IMPRESORA\">PARTES PARA IMPRESORA</option>\r\n                                <option value=\"PARTES DE CARROCERIA\" label=\"PARTES DE CARROCERIA\">PARTES DE CARROCERIA</option>\r\n                                <option value=\"PASTILLAS\" label=\"PASTILLAS\">PASTILLAS</option>\r\n                                <option value=\"PERFUMES\" label=\"PERFUMES\">PERFUMES</option>\r\n                                <option value=\"ROPA\" label=\"ROPA\">ROPA</option>\r\n                                <option value=\"ROPA DE CAMA\" label=\"ROPA DE CAMA\">ROPA DE CAMA</option>\r\n                                <option value=\"REPUESTOS PARA VEHICULO\" label=\"REPUESTOS PARA VEHICULO\">REPUESTOS PARA VEHICULO</option>\r\n                                <option value=\"REVISTAS\" label=\"REVISTAS\">REVISTAS</option>\r\n                                <option value=\"RELOJ\" label=\"RELOJ\">RELOJ</option>\r\n                                <option value=\"REPUESTOS PARA MOTOCICLETA\" label=\"REPUESTOS PARA MOTOCICLETA\">REPUESTOS PARA MOTOCICLETA</option>\r\n                                <option value=\"REPUESTOS PARA CUADRACICLO\" label=\"REPUESTOS PARA CUADRACICLO\">REPUESTOS PARA CUADRACICLO</option>\r\n                                <option value=\"SILLA DE SEGURIDAD PARA BEBE\" label=\"SILLA DE SEGURIDAD PARA BEBE\">SILLA DE SEGURIDAD PARA BEBE</option>\r\n                                <option value=\"SUPLEMENTO ALIMENTICIO\" label=\"SUPLEMENTO ALIMENTICIO\">SUPLEMENTO ALIMENTICIO</option>\r\n                                <option value=\"TARJETAS COLECCIONABLES\" label=\"TARJETAS COLECCIONABLES\">TARJETAS COLECCIONABLES</option>\r\n                                <option value=\"TELEFONOS DE LINEA FIJA\" label=\"TELEFONOS DE LINEA FIJA\">TELEFONOS DE LINEA FIJA</option>\r\n                                <option value=\"TELEVISORES\" label=\"TELEVISORES\">TELEVISORES</option>\r\n                                <option value=\"TINTAS \" label=\"TINTAS \">TINTAS </option>\r\n                                <option value=\"TONNER PARA IMPRESORA\" label=\"TONNER PARA IMPRESORA\">TONNER PARA IMPRESORA</option>\r\n                            </select>\r\n                        </div>\r\n                        <div>\r\n                            <label style=\"display: inline-block; font-weight: bold;\">Descripción:</label>\r\n                            <textarea id='descripcionFactura' cols='4' name='descripcionFactura' style=\"display: block; height: 74px; width: 90%;\"></textarea>\r\n                        </div>\r\n                        <h3 style=\"border-bottom: 2px #92c846 solid;\">Subir Archivo</h3>\r\n                        <div>\r\n                            <input type=\"file\" id=\"ClientInvoiceFile\" name=\"ClientInvoiceFile\" />\r\n                            <p><i>Acepta PDF e imagenes solamente</i></p>\r\n                        </div>\r\n                        <h3 style=\"border-bottom: 2px #92c846 solid;\">Copiar y Pegar Texto</h3>\r\n                        <div id=\"textAreaPlace\"></div>\r\n                    </div>\r\n                    <p style=\"width: 100%; text-align: center;\">\r\n                        <input type=\"submit\" class=\"uploadButton\" id=\"btnUploadClientInvoice\" value=\"Enviar Factura\" />\r\n                    </p>\r\n                    <input type=\"text\" name=\"WRId\" id=\"WRId\" style=\"visibility: hidden;\" />\r\n                </form>\r\n            </div>\r\n            <div class=\"loadingInvoicePanel\" style=\"display: none;\">\r\n                <p style=\"width: 100%; text-align: center;\">\r\n                    Guardando informaci&oacute;n de la factura enviada...\r\n                </p>\r\n                <p style=\"width: 100%; text-align: center;\">\r\n                    <img src=\"../../Content/Images/ajax-loader1.gif\" style=\"border: 0px;\" />\r\n                </p>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n\r\n    <div id=\"checksdiv\">\r\n    </div>\r\n\r\n\r\n        </div>\r\n        <div id=\"footer\">\r\n        </div>\r\n        \r\n    </div>\r\n    \r\n    <script src=\"../../Scripts/jquery-1.11.1.min.js\" type=\"text/javascript\"></script> \r\n    <script src=\"../../Scripts/menu-responsive.js\" type=\"text/javascript\"></script>\r\n    \r\n    <script type=\"text/javascript\">\r\n        $(document).ready(function () {\r\n            ///Loading animation\r\n            $body = $(\"body\");\r\n\r\n            $(document).on({\r\n                ajaxStart: function () {\r\n                    $body.addClass(\"loading\");\r\n                },\r\n                ajaxStop: function () {\r\n                    $body.removeClass(\"loading\");\r\n                }\r\n            });\r\n        });\r\n\r\n        $.fn.hoverClass = function (c) {\r\n            return this.each(function () {\r\n                $(this).hover(\r\n            function () { $(this).addClass(c); },\r\n            function () { $(this).removeClass(c); }\r\n            );\r\n            });\r\n        };\r\n\r\n    </script>\r\n    \r\n    \r\n\r\n    <script src=\"../../Scripts/jqueryui-1.11.1/jquery-ui.min.js\" type=\"text/javascript\"></script>\r\n\r\n    <!--\r\n  \r\n  <script src=\"/Scripts/jquery-ui-1.8.6.custom.min.js\" type=\"text/javascript\"></script>\r\n  \r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.core.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.widget.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.position.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.accordion.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.dialog.js\"></script>\r\n    \r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.ui.datepicker.js\"></script>\r\n    -->\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.json-2.2.min.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.validate.js\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.print.js\"></script>\r\n    <script type=\"text/javascript\" src=\"//cdn.jsdelivr.net/npm/sweetalert2@11\"></script>\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.tablesorter.min.js\"></script>\r\n    <script src=\"/Scripts/tiny.editor.packed.js\" type=\"text/javascript\"></script>\r\n    <script src=\"/Scripts/jquery.mask.min.js\" type=\"text/javascript\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"../../Scripts/jquery.signalR-2.2.0.min.js\"></script>\r\n\r\n    <script src=\"/Scripts/jquery.tablesorter.pager.js\" type=\"text/javascript\"></script>\r\n    <script src=\"/signalr/hubs\" type=\"text/javascript\"></script>\r\n\r\n\r\n\r\n    <script type=\"text/javascript\">\r\n        var idInterval = 0,\r\n            warehouseReceiptHub = null;\r\n\r\n        $(window).unload(function () {\r\n            clearInterval(idInterval);\r\n        });\r\n\r\n        $(function () {\r\n\r\n            $(\"#btnImprimirRecibos\").attr('disabled', true);\r\n            $(\"#btnImprimirEtiquetas\").attr('disabled', true);\r\n\r\n            if ((($(\"#WareHouseReceipts\").val() != \"\") && ($(\"#WareHouseReceipts\").val() != \"[]\")) || (($(\"#BoxingWareHouseReceipts\").val() != \"\") && ($(\"#BoxingWareHouseReceipts\").val() != \"[]\"))) {\r\n                $(\"#btnCrearMAWB\").attr('disabled', false);\r\n            }\r\n            else {\r\n                $(\"#btnCrearMAWB\").attr('disabled', true);\r\n            }\r\n\r\n            warehouseReceiptHub = $.connection.warehouseReceiptHub;\r\n            warehouseReceiptHub.client.actualizarImpresoConsolidado = function (idWarehouseReceipt, isImpreso, isConsolidado) {\r\n                var checkboxImpreso = $(\"#\" + idWarehouseReceipt + \"_Impreso\");\r\n                var checkboxConsolidado = $(\"#\" + idWarehouseReceipt + \"_Consolidado\");\r\n\r\n                checkboxImpreso.prop(\"checked\", isImpreso);\r\n                checkboxConsolidado.prop(\"checked\", isConsolidado);\r\n                console.log(\"Actualizado - Impreso/Consolidado\");\r\n            };\r\n            // Start the connection.\r\n            $.connection.hub.start().done(function () {\r\n                console.log(\"SignalR / Started\");\r\n            });\r\n        });\r\n\r\n        $(document).ready(function () {\r\n            $('#WarehouseReceiptStartDateSearchTerm').datepicker({ dateFormat: 'dd-mm-yy' });\r\n            $('#WarehouseReceiptEndDateSearchTerm').datepicker({ dateFormat: 'dd-mm-yy' });\r\n\r\n            $(\"#sortablelist\").tablesorter({\r\n                dateFormat: \"uk\", headers: {\r\n                    0: { sorter: false },\r\n                    2: { sorter: false },\r\n                    3: { sorter: false }\r\n                }\r\n            });\r\n        });\r\n\r\n        var arr = new Array();\r\n        var arrReempaque = new Array();\r\n        var arrImpresion = new Array();\r\n\r\n        function onchangethecheckbox(check) {\r\n            var arrString = new Array();\r\n            arrString = check.name.split('_');\r\n            if (arrString[1] == \"Normal\") {\r\n                if ($(\"#WareHouseReceipts\").val() != \"\") {\r\n                    arr = eval($(\"#WareHouseReceipts\").val());\r\n                }\r\n                var founded = 0;\r\n                for (var i = 0; i < arr.length; i++) {\r\n                    if (arr[i].Idwarehousereceipt == arrString[0]) {\r\n                        arr = jQuery.grep(arr, function (value) { return value.Idwarehousereceipt != arrString[0]; });\r\n                        var control = \"#\" + arrString[0] + \"_Reempaque\";\r\n                        var idrow = \"#row\" + arrString[0];\r\n                        $(idrow).remove();\r\n                        $(control).attr('disabled', false);\r\n                        founded = 1;\r\n                        i = arr.length;\r\n                    }\r\n                }\r\n\r\n                if (founded != 1) {\r\n                    var var1 = \"#WhrNumber-\" + arrString[0];\r\n                    var var2 = \"#WhrNotes-\" + arrString[0];\r\n                    var var3 = \"#WhrCharges-\" + arrString[0];\r\n                    var var4 = \"#WhrConsignee-\" + arrString[0];\r\n                    var test =\r\n                    {\r\n                        Idwarehousereceipt: arrString[0],\r\n                        Number: $(var1).val(),\r\n                        Consignee: { ConsigneeName: $(var4).val() },\r\n                        ConsigneeNotes: $(var2).val()\r\n                    };\r\n                    arr[arr.length] = test;\r\n                    $('#tablenormal tbody').append('<tr id=\"row' + arrString[0] + '\">' +\r\n                        '<td>' + $(var1).val() + '</td>' +\r\n                        '<td>' + $(var4).val() + '</td>' +\r\n                        '<td>' + $(var2).val() + '</td>' +\r\n                        '<td>' + $(var3).val() + '</td>' +\r\n                        '</tr>');\r\n                    var control = \"#\" + arrString[0] + \"_Reempaque\";\r\n                    $(control).attr('disabled', true);\r\n                }\r\n                var jsonTest = $.toJSON(arr);\r\n                $(\"#WareHouseReceipts\").val(jsonTest);\r\n\r\n                if ((($(\"#WareHouseReceipts\").val() != \"\") && ($(\"#WareHouseReceipts\").val() != \"[]\")) || (($(\"#BoxingWareHouseReceipts\").val() != \"\") && ($(\"#BoxingWareHouseReceipts\").val() != \"[]\"))) {\r\n                    $(\"#btnCrearMAWB\").attr('disabled', false);\r\n                }\r\n                else {\r\n                    $(\"#btnCrearMAWB\").attr('disabled', true);\r\n                }\r\n            }\r\n            else {\r\n                if (arrString[1] == \"Reempaque\") {\r\n                    if ($(\"#BoxingWareHouseReceipts\").val() != \"\") {\r\n                        arrReempaque = eval($(\"#BoxingWareHouseReceipts\").val());\r\n                    }\r\n                    var founded = 0;\r\n                    for (var i = 0; i < arrReempaque.length; i++) {\r\n                        if (arrReempaque[i].Idwarehousereceipt == arrString[0]) {\r\n                            arrReempaque = jQuery.grep(arrReempaque, function (value) { return value.Idwarehousereceipt != arrString[0]; });\r\n                            var control = \"#\" + arrString[0] + \"_Normal\";\r\n                            var idrow = \"#row\" + arrString[0];\r\n                            $(idrow).remove();\r\n                            $(control).attr('disabled', false);\r\n                            founded = 1;\r\n                            i = arrReempaque.length;\r\n                        }\r\n                    }\r\n                    if (founded != 1) {\r\n                        var var1 = \"#WhrNumber-\" + arrString[0];\r\n                        var var2 = \"#WhrNotes-\" + arrString[0];\r\n                        var var3 = \"#WhrCharges-\" + arrString[0];\r\n                        var var4 = \"#WhrConsignee-\" + arrString[0];\r\n                        var var5 = \"#WhrSucursal-\" + arrString[0];\r\n                        var test = {\r\n                            Idwarehousereceipt: arrString[0],\r\n                            Number: $(var1).val(),\r\n                            Consignee: { ConsigneeName: $(var4).val() },\r\n                            ConsigneeNotes: $(var2).val()\r\n                        };\r\n                        arrReempaque[arrReempaque.length] = test;\r\n\r\n                        //Necesito la tabla para la sucursal seleccionada\r\n                        //                            alert($(var5).val());\r\n                        var nombreTablaSucursal = '#tablereempaque' + $(var5).val() + ' tbody';\r\n                        //                            alert(nombreTablaSucursal);\r\n                        $(nombreTablaSucursal).append('<tr id=\"row' + arrString[0] + '\">' +\r\n                            '<td>' + $(var1).val() + '</td>' +\r\n                            '<td>' + $(var4).val() + '</td>' +\r\n                            '<td>' + $(var2).val() + '</td>' +\r\n                            '<td>' + $(var3).val() + '</td>' +\r\n                            '</tr>');\r\n                        var control = \"#\" + arrString[0] + \"_Normal\";\r\n                        $(control).attr('disabled', true);\r\n                    }\r\n\r\n                    var jsonTest = $.toJSON(arrReempaque);\r\n                    $(\"#BoxingWareHouseReceipts\").val(jsonTest);\r\n\r\n                    if ((($(\"#WareHouseReceipts\").val() != \"\") && ($(\"#WareHouseReceipts\").val() != \"[]\")) || (($(\"#BoxingWareHouseReceipts\").val() != \"\") && ($(\"#BoxingWareHouseReceipts\").val() != \"[]\"))) {\r\n                        $(\"#btnCrearMAWB\").attr('disabled', false);\r\n                    }\r\n                    else {\r\n                        $(\"#btnCrearMAWB\").attr('disabled', true);\r\n                    }\r\n                }\r\n                else {\r\n                    if (arrString[1] == \"Imprimir\") {\r\n                        var founded = 0;\r\n                        for (var i = 0; i < arrImpresion.length; i++) {\r\n                            if (arrImpresion[i].Idwarehousereceipt == arrString[0]) {\r\n                                arrImpresion = jQuery.grep(arrImpresion, function (value) { return value.Idwarehousereceipt != arrString[0]; });\r\n                                founded = 1;\r\n                                i = arrImpresion.length;\r\n                            }\r\n                        }\r\n                        if (founded != 1) {\r\n                            var test = {\r\n                                Idwarehousereceipt: arrString[0]\r\n                            };\r\n                            arrImpresion[arrImpresion.length] = test;\r\n                        }\r\n                        var jsonTest = $.toJSON(arrImpresion);\r\n                        $(\"#WareHouseReceiptsForPrint\").val(jsonTest);\r\n                        $(\"#WareHouseReceiptsEtiquetasForPrint\").val(jsonTest);\r\n\r\n                        if (($(\"#WareHouseReceiptsForPrint\").val() != \"\") && ($(\"#WareHouseReceiptsForPrint\").val() != \"[]\")) {\r\n                            $(\"#btnImprimirRecibos\").attr('disabled', false);\r\n                            $(\"#btnImprimirEtiquetas\").attr('disabled', false);\r\n                        }\r\n                        else {\r\n                            $(\"#btnImprimirRecibos\").attr('disabled', true);\r\n                            $(\"#btnImprimirEtiquetas\").attr('disabled', true);\r\n                        }\r\n                    }\r\n                }\r\n            }\r\n\r\n        }\r\n\r\n        function imprimirListas() {\r\n            $(\"#printdiv\").focus();\r\n            $(\"#printdiv\").print();\r\n        }\r\n\r\n        function chkWarehouseReceiptNumberChange() {\r\n            var checkeado = $(\"#chkWarehouseReceiptNumber\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkWarehouseReceiptNumber\", \"ischecked\": checkeado });\r\n            var count1 = parseInt($(\"#listcount\").val());\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#numberrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#numberheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n\r\n                    var controlname = \"#numberrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#numberheader\").hide();\r\n            }\r\n        }\r\n        function chkDateChange() {\r\n            var checkeado = $(\"#chkDate\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkDate\", \"ischecked\": checkeado });\r\n            var count1 = parseInt($(\"#listcount\").val());\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n\r\n                    var controlname = \"#daterow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#dateheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n\r\n                    var controlname = \"#daterow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#dateheader\").hide();\r\n            }\r\n        }\r\n        function chkStatusChange() {\r\n            var checkeado = $(\"#chkStatus\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkStatus\", \"ischecked\": checkeado });\r\n            var count1 = parseInt($(\"#listcount\").val());\r\n            if (checkeado) {\r\n\r\n                for (var i = 0; i < count1; i++) {\r\n\r\n                    var controlname = \"#statusrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#statusheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#statusrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#statusheader\").hide();\r\n            }\r\n        }\r\n        function chkConsigneeChange() {\r\n            var checkeado = $(\"#chkConsignee\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkConsignee\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#consigneerow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#consigneeheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#consigneerow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#consigneeheader\").hide();\r\n            }\r\n        }\r\n        function chkTrackingNumberChange() {\r\n            var checkeado = $(\"#chkTrackingNumber\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkTrackingNumber\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#trackingrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#trackingheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#trackingrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#trackingheader\").hide();\r\n            }\r\n        }\r\n        function chkShipperChange() {\r\n            var checkeado = $(\"#chkShipper\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkShipper\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#shipperrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#shipperheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#shipperrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#shipperheader\").hide();\r\n            }\r\n        }\r\n        function chkCarrierChange() {\r\n            var checkeado = $(\"#chkCarrier\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkCarrier\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#carrierrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#carrierheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#carrierrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#carrierheader\").hide();\r\n            }\r\n        }\r\n        function chkTotalPiecesChange() {\r\n            var checkeado = $(\"#chkTotalPieces\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkTotalPieces\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#piecesrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#piecesheader\").show();\r\n  