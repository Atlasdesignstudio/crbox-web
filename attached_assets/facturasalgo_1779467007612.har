            "size": 1729636,
            "mimeType": "text/html",
            "text": "\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n<head><link rel=\"shortcut icon\" href=\"http://crbox.co.cr/favicon.png\" /><link href=\"Content/Site.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n    <!--<link href=\"Content/jquery-ui-1.8rc3.custom.css\" rel=\"stylesheet\" type=\"text/css\" />-->\r\n    <link href=\"Content/CrBoxStyle.css\" rel=\"stylesheet\" type=\"text/css\" /><link href=\"Content/menu-responsive.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n    <title>Active Warehouse Receipts</title>\r\n    <link type=\"text/css\" href=\"../../Content/jquery-ui.min.css\" rel=\"stylesheet\" />\r\n    <link rel=\"Stylesheet\" type=\"text/css\" href=\"/Content/popupEmitirEtiquetasEcon.css\" />\r\n    <link rel=\"Stylesheet\" type=\"text/css\" href=\"/Content/tinyeditor.css\" />\r\n<title>\r\n\tActive Warehouse Receipts\r\n</title></head>\r\n<body>\r\n     <div class=\"loaderImage\">\r\n        <!-- Loading indicator -->\r\n    </div>\r\n    <div class=\"page\">\r\n        <div id=\"header\">\r\n            <div id=\"title\">\r\n                <img src=\"../../Content/Images/logo.png\" alt=\"CrBox Delivery System Admin Site\" />\r\n                <div id=\"welcomediv\">\r\n                 - Hola meneses@crbox.cr\r\n                    <a href=\"/Account/LogOff\">Cerrar sesi&#243;n</a>\r\n                </div>\r\n            </div>\r\n            \r\n            <br />\r\n            <br />\r\n            <div id=\"menucontainer\">\r\n                    <div>\r\n                    <div id='cssmenu'>\r\n                    <ul>\r\n                    <!--<ul id=\"jqueryuimenu\">-->\r\n                        \r\n                        \r\n                        <li>\r\n                            <a href=\"/WareHouseReceipt\">ReciboBodega</a>\r\n                        </li>\r\n                        \r\n                        <li>\r\n                            <a href=\"/MastAirShipment\">MAWB</a>\r\n                        </li>\r\n                        <li>\r\n                            <li>\r\n                                <a href=\"/Home/Index2\">Consignees</a>\r\n                                <ul>\r\n                                    <li>\r\n                                        <a href=\"/Consignee\">Ver Consignees</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a href=\"/Consignee/DetailsSummary\">Buscar Hist&#243;rico</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a href=\"/Consignee/SearchConsignees\">B&#250;squeda por Fecha y Sucursal</a>\r\n                                    </li>\r\n                                </ul>\r\n                            </li>\r\n                        </li>\r\n                        <li>\r\n                            <a href=\"/Shipper\">Shipper</a>\r\n                        </li>\r\n                        <li>\r\n                            <a href=\"/Supplier\">Supplier</a>\r\n                        </li>                        \r\n                        <li>\r\n                            <a href=\"/Carrier\">Carrier</a>\r\n                        </li>\r\n                        \r\n                        <li>\r\n                            <a href=\"/CrboxAirshipment\">GuiaCrbox</a>\r\n                        </li>\r\n                        \r\n                        <li>\r\n                            <li>\r\n                                <a href=\"/Home/Index2\">Fact. Aduanal</a>\r\n                                <ul>\r\n                                    <li>\r\n                                        <a href=\"/FacturaAduanal\">Listar Facturas</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a href=\"/ResumenMAWB/SearchClientInvoiceDetail\">Consulta de Factura</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a href=\"/Store\">Listar Tiendas</a>\r\n                                    </li>\r\n                                </ul>\r\n                            </li>\r\n                        </li>\r\n                        \r\n                        <li>\r\n                            <a href=\"/Company\">Empresas</a>\r\n                        </li>\r\n                        <li>\r\n                            <a href=\"/Home/Index2\">Security</a>\r\n                            <ul>\r\n                                <li>\r\n                                    <a href=\"/Account/Register\">Add User</a>\r\n                                </li>\r\n                                \r\n                                <li>\r\n                                     <a href=\"/DescuentoCorporativo\">Desc. Empresas</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a href=\"/Sucursal\">Sucursales</a>\r\n                                </li>\r\n                                <li>\r\n\r\n                                    \r\n                                       \r\n                                    <a href=\"/Account\">Users</a>\r\n                                </li>\r\n                                \r\n                            </ul>\r\n                        </li>\r\n                        <li>\r\n                            <a href=\"/Discounts\">Otros</a>\r\n                            <ul>\r\n                                <li>\r\n                                    <a href=\"/Discounts\">Descuentos</a>\r\n                                </li>\r\n        \r\n                                <li>\r\n                                    <a href=\"/Newsletters\">Enviar Mensajes</a>\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        \r\n                        \r\n                    </ul>\r\n                </div>\r\n                \r\n            </div>\r\n        </div>\r\n        <div id=\"main\">\r\n            \r\n    <h2>Active Warehouse Receipts</h2>\r\n    <table class=\"tdSinborde\">\r\n        <tr>\r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/WareHouseReceipt\" id=\"searchForm\" method=\"post\">\r\n                <fieldset>\r\n                    <legend>Criterios de Búsqueda</legend>\r\n                    <table class=\"tdSinborde\">\r\n                        <tr>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"StartDate\">\r\n                                    Start date:</label>\r\n                                <input data-val=\"true\" data-val-date=\"The field WarehouseReceiptStartDateSearchTerm must be a date.\" id=\"WarehouseReceiptStartDateSearchTerm\" name=\"WarehouseReceiptStartDateSearchTerm\" style=\"width:80px\" type=\"text\" value=\"01-05-2026\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"EndDate\">\r\n                                    End date:</label>\r\n                                <input data-val=\"true\" data-val-date=\"The field WarehouseReceiptEndDateSearchTerm must be a date.\" id=\"WarehouseReceiptEndDateSearchTerm\" name=\"WarehouseReceiptEndDateSearchTerm\" style=\"width:80px\" type=\"text\" value=\"22-05-2026\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"TrackingNumber\">\r\n                                    TrackingNumber:</label>\r\n                                <input id=\"TrackingNumberSearchTerm\" name=\"TrackingNumberSearchTerm\" style=\"width:200px\" type=\"text\" value=\"\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"CarrierSearchTerm\">\r\n                                    Carrier:</label>\r\n                                <input id=\"CarrierNombreSearchTerm\" name=\"CarrierNombreSearchTerm\" style=\"width:200px\" type=\"text\" value=\"\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"ShipperNombreSearchTerm\">\r\n                                    Shipper:</label>\r\n                                <input id=\"ShipperNombreSearchTerm\" name=\"ShipperNombreSearchTerm\" style=\"width:200px\" type=\"text\" value=\"\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"ConsigneeName\">\r\n                                    Consignee (Nombre):</label>\r\n                                <input id=\"ConsigneeNombreSearchTerm\" name=\"ConsigneeNombreSearchTerm\" style=\"width:200px\" type=\"text\" value=\"\" />\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <label for=\"ConsigneeName\">\r\n                                    Status:</label>\r\n                                <select data-val=\"true\" data-val-number=\"The field IdStatus must be a number.\" data-val-required=\"The IdStatus field is required.\" id=\"SelectedStatusSearchTerm_IdStatus\" name=\"SelectedStatusSearchTerm.IdStatus\"><option selected=\"selected\" value=\"1\">MIA</option>\r\n<option value=\"1000\">Todos</option>\r\n<option value=\"2\">SJO</option>\r\n<option value=\"3\">Loaded</option>\r\n<option value=\"4\">InTransit</option>\r\n<option value=\"5\">Crbox</option>\r\n<option value=\"6\">En espera de factura</option>\r\n</select>\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input type=\"submit\" value=\"Buscar\" />\r\n                            </td>\r\n                        </tr>\r\n                    </table>\r\n                </fieldset>\r\n                <fieldset>\r\n                    <legend>Columnas</legend>\r\n                    <table>\r\n                        <tr>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkWarehouseReceiptNumber\" name=\"chkWarehouseReceiptNumber\" onChange=\"chkWarehouseReceiptNumberChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkWarehouseReceiptNumber\" type=\"hidden\" value=\"false\" />\r\n                                WR#\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkDate\" name=\"chkDate\" onChange=\"chkDateChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkDate\" type=\"hidden\" value=\"false\" />\r\n                                ReceivedDate\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkStatus\" name=\"chkStatus\" onChange=\"chkStatusChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkStatus\" type=\"hidden\" value=\"false\" />\r\n                                Status\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkConsignee\" name=\"chkConsignee\" onChange=\"chkConsigneeChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkConsignee\" type=\"hidden\" value=\"false\" />\r\n                                Consignee\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkTrackingNumber\" name=\"chkTrackingNumber\" onChange=\"chkTrackingNumberChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkTrackingNumber\" type=\"hidden\" value=\"false\" />\r\n                                TrackingNumber\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkCarrier\" name=\"chkCarrier\" onChange=\"chkCarrierChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkCarrier\" type=\"hidden\" value=\"false\" />\r\n                                Carrier\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkShipper\" name=\"chkShipper\" onChange=\"chkShipperChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkShipper\" type=\"hidden\" value=\"false\" />\r\n                                Shipper\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkTotalPieces\" name=\"chkTotalPieces\" onChange=\"chkTotalPiecesChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkTotalPieces\" type=\"hidden\" value=\"false\" />\r\n                                Pieces\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkTotalWeight\" name=\"chkTotalWeight\" onChange=\"chkTotalWeightChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkTotalWeight\" type=\"hidden\" value=\"false\" />\r\n                                Weight\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkTotalVolumetricWeight\" name=\"chkTotalVolumetricWeight\" onChange=\"chkTotalVolumetricWeightChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkTotalVolumetricWeight\" type=\"hidden\" value=\"false\" />\r\n                                VolumetricWeight\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkTotalVolume\" name=\"chkTotalVolume\" onChange=\"chkTotalVolumeChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkTotalVolume\" type=\"hidden\" value=\"false\" />\r\n                                Volume\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkNotes\" name=\"chkNotes\" onChange=\"chkNotesChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkNotes\" type=\"hidden\" value=\"false\" />\r\n                                Notes\r\n                            </td>\r\n                            <td class=\"tdSinborde\">\r\n                                <input checked=\"checked\" id=\"chkCreatedBy\" name=\"chkCreatedBy\" onChange=\"chkCreatedByChange()\" type=\"checkbox\" value=\"true\" /><input name=\"chkCreatedBy\" type=\"hidden\" value=\"false\" />\r\n                                CreatedBy\r\n                            </td>\r\n                        </tr>\r\n                    </table>\r\n                </fieldset>\r\n                </form>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n    <table class=\"tdSinborde\" style=\"font-size: 11px\">\r\n        <tr>\r\n            <td class=\"tdSinborde\">\r\n                <div style=\"width: 75px\">\r\n                    <a href=\"/WareHouseReceipt/Create\">Crear Nuevo</a>\r\n                    \r\n                </div>\r\n            </td>\r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/WareHouseReceipt\" method=\"get\">\r\n                <input type=\"submit\" style=\"font-size: 12px\" value=\"Refresh\" />\r\n                </form>\r\n            </td>\r\n            \r\n            <td class=\"tdSinborde\">\r\n                    <input id=\"btnopciones\" type=\"button\" style=\"font-size: 12px\" value=\"Emisión de etiquetas E-Cont\"/>\r\n                    <div id=\"popupEmision\">\r\n                        <form action=\"/\" method=\"post\"></form>\r\n                        <form action=\"/WareHouseReceipt/EmisionEtiqueta\" method=\"post\">\r\n\r\n                            <h2>Escriba el número de guía aérea:</h2>\r\n                            <input type=\"text\" name=\"guiaAerea\" style=\"font-size: 12px; width: 60%; padding: 12px 20px; margin: 8px 0; box-sizing: border-box;\" required=\"required\"/>\r\n                            \r\n                            <input class=\"buttonEmision\" type=\"submit\" style=\"font-size: 12px;\" value=\"Imprimir no impresas\" />\r\n                            \r\n                            </form>\r\n                        \r\n                        <input class=\"buttonEmision\" onclick=\"toggleEmision()\" type=\"button\"  value=\"Cerrar\"/>\r\n\r\n                    </div>\r\n             </td>\r\n                        <td class=\"tdSinborde\">\r\n                             <input id=\"btnopciones2\" type=\"button\" style=\"font-size: 12px\" value=\"Emisión de etiquetas Normal\"/>\r\n                             <div id=\"popupEmision2\">\r\n                                 <form action=\"/\" method=\"post\"></form>\r\n                                <form action=\"/WareHouseReceipt/EmisionEtiqueta2\" method=\"post\">\r\n                                        <h2>Número de guía aérea para etiquetas normal: </h2>\r\n                                        <input type=\"text\" name=\"guiaAerea\" style=\"font-size: 12px; width: 60%; padding: 12px 20px; margin: 8px 0; box-sizing: border-box;\" required=\"required\"/>\r\n                            \r\n                                        <input class=\"buttonEmision\" type=\"submit\" style=\"font-size: 12px;\" value=\"Imprimir no impresas\" />\r\n\r\n                                 </form>\r\n                                 <input class=\"buttonEmision\" onclick=\"toggleEmision2()\" type=\"button\"  value=\"Cerrar\"/>\r\n                            </div>\r\n                     </td>\r\n\r\n            <td class=\"tdSinborde\">\r\n                <input onclick=\"imprimirListas()\" style=\"font-size: 12px\" type=\"button\" value=\"Imprimir lista de bodega\" />\r\n            </td>\r\n            \r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/EtiquetaEntrega/WarehousereceiptsEtiquetasPrint2\" method=\"post\"><input id=\"WareHouseReceiptsEtiquetasForPrint\" name=\"WareHouseReceiptsEtiquetasForPrint\" type=\"hidden\" value=\"\" />\r\n                <input type=\"submit\" style=\"font-size: 12px\" id=\"btnImprimirEtiquetas\" value=\"Imprimir Etiquetas\" />\r\n                </form>\r\n            </td>\r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/WareHouseReceipt/ImprimirRecibos\" method=\"post\"><input id=\"WareHouseReceiptsForPrint\" name=\"WareHouseReceiptsForPrint\" type=\"hidden\" value=\"\" />\r\n                <input type=\"submit\" style=\"font-size: 12px\" id=\"btnImprimirRecibos\" value=\"Imprimir Recibos\" />\r\n                </form>\r\n            </td>\r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/WareHouseReceipt/ImprimirRecibosMiami\" method=\"post\">\r\n                <input type=\"submit\" style=\"font-size: 12px\" value=\"Imprimir Recibos Miami\" />\r\n                </form>\r\n            </td>\r\n            \r\n            <td class=\"tdSinborde\">\r\n                \r\n                <input type=\"submit\" style=\"font-size: 12px\" onclick=\"GuardarAereo()\" value=\"Guardar Aéreo\" />\r\n                \r\n            </td>\r\n            <td class=\"tdSinborde\">\r\n                <form action=\"/MastAirShipment/Create\" method=\"post\"><input id=\"WareHouseReceipts\" name=\"WareHouseReceipts\" type=\"hidden\" value=\"[]\" />\r\n                <input id=\"BoxingWareHouseReceipts\" name=\"BoxingWareHouseReceipts\" type=\"hidden\" value=\"[]\" />\r\n                \r\n                <input type=\"submit\" style=\"font-size: 12px\" id=\"btnCrearMAWB\" value=\"Create MAWB\" />\r\n                </form>\r\n            </td>\r\n            \r\n            <td class=\"tdSinborde\">\r\n                <table>\r\n                    <tr>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/InMiami.png\" />\r\n                            MIAMI\r\n                        </td>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/InLoaded.png\" />\r\n                            LOADED\r\n                        </td>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/EnEspera.png\" />\r\n                            EN ESPERA DE FACTURA\r\n                        </td>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/InProcess.png\" />\r\n                            IN TRANSIT\r\n                        </td>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/InSJO.png\" />\r\n                            SJO\r\n                        </td>\r\n                        <td class=\"tdSinborde\">\r\n                            <input type=\"image\" src=\"../../Content/Images/InCrbox.png\" />\r\n                            CRBO