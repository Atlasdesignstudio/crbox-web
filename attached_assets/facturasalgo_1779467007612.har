            "mimeType": "text/css",
            "text": "/* casilla micrbox*/\r\n.micrbox\r\n{\r\n\tpadding-top: 20px;\r\n\theight: 232px;\r\n\twidth: 173px;\r\n\tfont-size: 12px;\r\n\tfloat: right;\r\n}\r\n.micrbox .textboxes\r\n{\r\n\twidth: 150px;\r\n}\r\n.micrbox form\r\n{\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 11px;\r\n\tmargin: 13px 0 0 19px;\r\n\tfont-size: 11px;\r\n\theight: 120px;\r\n}\r\n.micrbox .ingresar\r\n{\r\n\tmargin: 13px 0 0 76px;\r\n}\r\n.micrbox .contrasena\r\n{\r\n\tmargin: 2px 0 0;\r\n}\r\n.micrbox .submit\r\n{\r\n\tmargin: 12px 0 0 0;\r\n}\r\n.micrbox .forget\r\n{\r\n\tfloat: right;\r\n\theight: 10px;\r\n\tmargin: 10px 11px 0 0;\r\n\twidth: 51px;\r\n\theight: 25px;\r\n\ttext-align: right;\r\n}\r\n.micrbox .forget a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 10px;\r\n\tfont-weight: bold;\r\n}\r\n.micrbox .paquetes\r\n{\r\n\tpadding: 12px 0 0 30px;\r\n\twidth: 80px;\r\n\theight: 28px;\r\n\tfont-size: 11px;\r\n}\r\n.micrbox .paquetes a\r\n{\r\n\tcolor: #FFFFFF;\r\n\ttext-decoration: none;\r\n}\r\n.micrbox .cuentabanco\r\n{\r\n\tfont-size: 11px;\r\n\tpadding: 22px 10px 0 30px;\r\n}\r\n.micrbox .cuentabanco a\r\n{\r\n\tcolor: #FFFFFF;\r\n\ttext-decoration: none;\r\n}\r\n\r\n/* mapa*/\r\n.mapa\r\n{\r\n\tbackground: transparent url(Images/main_banner.png) no-repeat scroll 0 0;\r\n\tfloat: left;\r\n\theight: 246px;\r\n\twidth: 538px;\r\n}\r\n.mapa .link\r\n{\r\n\tbackground: url(Images/barralink.png) no-repeat;\r\n\ttext-decoration: none;\r\n\twidth: 176px;\r\n\theight: 34px;\r\n\tposition: relative;\r\n\ttop: 148px;\r\n\tleft: 138px;\r\n}\r\n.mapa .link a\r\n{\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 28px;\r\n\tfont-weight: bold;\r\n\tposition: relative;\r\n\tleft: 24px;\r\n\ttext-decoration: none;\r\n\tletter-spacing: -2px;\r\n}\r\n\r\n\r\n\r\n\r\n/*transporte*/\r\n.transporte\r\n{\r\n\tbackground: url(Images/transporte.png) no-repeat;\r\n\theight: 32px;\r\n\tmargin: -4px 0 0 0;\r\n\tfloat: left;\r\n\twidth: 719px;\r\n}\r\n.transporte li\r\n{\r\n\tdisplay: block;\r\n\tfloat: left;\r\n\tlist-style-type: none;\r\n}\r\n.transporte li a\r\n{\r\n\tpadding: 7px 23px;\r\n\tcolor: #ffffff;\r\n\tdisplay: block;\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\theight: 20px;\r\n\ttext-decoration: none;\r\n\twidth: 138px;\r\n}\r\n.transporte .aereo\r\n{\r\n\tpadding: 2px 0 0 199px;\r\n}\r\n.transporte .aereo a\r\n{\r\n\twidth: 92px;\r\n}\r\n.transporte .maritimo a\r\n{\r\n\twidth: 151px;\r\n}\r\n.transporte .terrestre a\r\n{\r\n}\r\n\r\n/*banner promos*/\r\n.promos\r\n{\r\n\theight: 235px;\r\n\twidth: 720px;\r\n}\r\n.promos div\r\n{\r\n\tfloat: left;\r\n\tmargin: 0 0 0 3px;\r\n}\r\n.promos .rectone\r\n{\r\n\t/*background: url(Images/rectone.png) no-repeat;*/\r\n\tmargin: 13px 0 0 9px;\r\n\theight: 230px;\r\n\twidth: 176px;\r\n}\r\n.promos .recttwo\r\n{\r\n\t/*background: url(Images/recttwo.png) no-repeat;*/\r\n\theight: 226px;\r\n\tmargin: 14px 0 0 5px;\r\n\twidth: 161px;\r\n}\r\n.promos .recthree\r\n{\r\n\tbackground: url(Images/one.png) no-repeat;\r\n\theight: 114px;\r\n\tmargin: 13px 0 0 5px;\r\n\twidth: 174px;\r\n}\r\n.promos .recthree a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tfloat: right;\r\n\tmargin: 80px 7px 0 0;\r\n}\r\n.promos .recfour\r\n{\r\n\tbackground: url(Images/two.png) no-repeat;\r\n\theight: 114px;\r\n\tmargin: 13px 0 0 6px;\r\n\twidth: 172px;\r\n}\r\n.promos .recfour a\r\n{\r\n\tcolor: #6C6C6C;\r\n\tfont-size: 12px;\r\n\tfloat: right;\r\n\tmargin: 79px 11px 0 0;\r\n\ttext-decoration: none;\r\n}\r\n.promos .rectfive\r\n{\r\n\tbackground: url(Images/three.png) no-repeat;\r\n\theight: 108px;\r\n\tmargin: 3px 0 0 5px;\r\n\twidth: 174px;\r\n}\r\n.promos .rectfive a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tcolor: #FFFFFF;\r\n\tfloat: right;\r\n\tfont-size: 12px;\r\n\tmargin: 77px 16px 0 0;\r\n\ttext-decoration: none;\r\n}\r\n.promos .rectsix\r\n{\r\n\tbackground: url(Images/four.png) no-repeat;\r\n\theight: 108px;\r\n\tmargin: 3px 0 0 6px;\r\n\twidth: 172px;\r\n}\r\n.promos .rectsix a\r\n{\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tfloat: right;\r\n\tmargin: 76px 5px 0 0;\r\n\ttext-decoration: none;\r\n}\r\n\r\n/*footer*/\r\n.footer\r\n{\r\n\tbackground: url(Images/direccion.png) no-repeat;\r\n\theight: 160px;\r\n\twidth: 722px;\r\n}\r\n\r\n\r\n.footer p\r\n{\r\n\tmargin: 3px 0 0 0;\r\n\tcolor: #015C7A;\r\n\tfont-size: 9px;\r\n\tfont-weight: bold;\r\n}\r\n.footer p b\r\n{\r\n\tmargin: 18px 0 15px 11px;\r\n\tfloat: left;\r\n}\r\n.utilitariomenu\r\n{\r\n\ttext-align: center;\r\n\tclear: both;\r\n}\r\n.utilitariomenu li\r\n{\r\n\tfont-size: 11px;\r\n\theight: 13px;\r\n\twidth: 315px;\r\n\tlist-style: none;\r\n\tdisplay: inline;\r\n\tfont-weight: bold;\r\n}\r\n.utilitariomenu a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #666666;\r\n}\r\n.copyright\r\n{\r\n\tcolor: #666666;\r\n\tfont-size: 11px;\r\n\tfont-weight: bold;\r\n\tmargin: 20px 0 0;\r\n\ttext-align: center;\r\n}\r\n/*Tools*/\r\n.clear\r\n{\r\n\tclear: both;\r\n}\r\n.buttonIMG\r\n{\r\n\tdisplay: block !important;\r\n\theight: 100% !important;\r\n\twidth: 100% !important;\r\n}\r\n\r\n/* banner info */\r\n.contderecha\r\n{\r\n\tfloat: right;\r\n\theight: 423px;\r\n\tmargin: 17px 2px 0 0;\r\n\twidth: 179px;\r\n}\r\n.contactenosBdC .contderecha\r\n{\r\n\tmargin: 22px 2px 0 0;\r\n\twidth: 183px;\r\n}\r\n.contderecha .info1\r\n{\r\n\tmargin: 15px 0 0 5px;\r\n}\r\n.contderecha .info3\r\n{\r\n\tmargin: 9px 0 0 6px;\r\n}\r\n\r\n\r\n.info1\r\n{\r\n\tbackground: url(Images/one.png) no-repeat;\r\n\theight: 114px;\r\n\twidth: 174px;\r\n}\r\n.info1 a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tposition: relative;\r\n\ttop: 80px;\r\n\tleft: 89px;\r\n\tfont-weight: bold;\r\n}\r\n.info2\r\n{\r\n\tbackground: url(Images/three.png) no-repeat;\r\n\theight: 110px;\r\n\twidth: 173px;\r\n\tmargin: 19px 0 0 8px;\r\n}\r\n\r\n.contactosAereosBdC .info2\r\n{\r\n\tmargin: 19px 0 0 0;\r\n}\r\n.contactosAereosBdC .maritima\r\n{\r\n\tmargin: 23px 0 0 0;\r\n}\r\n\r\n\r\n.info2 a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tposition: relative;\r\n\ttop: 80px;\r\n\tleft: 78px;\r\n\tfont-weight: bold;\r\n}\r\n.mision\r\n{\r\n\tbackground: url(Images/fondomision.png) no-repeat;\r\n\tfont-size: 11px;\r\n\tcolor: #ffffff;\r\n\theight: 105px;\r\n\tmargin: 5px 0 0 5px;\r\n\twidth: 176px;\r\n\tfont-weight: bold;\r\n}\r\n.mision b\r\n{\r\n\tcolor: #ffffff;\r\n\tfont-size: 13px;\r\n}\r\n.mision p\r\n{\r\n\tfloat: left;\r\n\tletter-spacing: -1px;\r\n\tmargin: 5px 0 0 4px;\r\n}\r\n.vision\r\n{\r\n\tbackground: url(Images/fondovision.png) no-repeat;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 11px;\r\n\tfont-weight: bold;\r\n\theight: 105px;\r\n\tmargin: 14px 0 0 3px;\r\n\twidth: 176px;\r\n}\r\n.vision b\r\n{\r\n\tcolor: #ffffff;\r\n\tfont-size: 13px;\r\n}\r\n.vision p\r\n{\r\n\tfloat: left;\r\n\tmargin: 5px 0 0 5px;\r\n}\r\n/* crbox-nuestra empresa*/\r\n.micrbox2\r\n{\r\n\tbackground: url(Images/Notext_myCrbox.png) no-repeat;\r\n\theight: 175px;\r\n\twidth: 175px;\r\n\tfont-size: 12px;\r\n}\r\n.micrbox2 form\r\n{\r\n\tleft: 10px;\r\n\tposition: relative;\r\n\ttop: 44px;\r\n\twidth: 158px;\r\n}\r\n.micrbox2 form .textField\r\n{\r\n\twidth: 129px;\r\n}\r\n.micrbox2 .contrasena\r\n{\r\n\tmargin: 7px 0 0 0px;\r\n}\r\n.micrbox2 .ingresar\r\n{\r\n\tmargin: 14px 0 0 76px;\r\n}\r\n.micrbox2 a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 10px;\r\n\tfont-style: italic;\r\n\tfont-weight: bold;\r\n\tleft: 42px;\r\n\tposition: relative;\r\n\ttext-decoration: none;\r\n\ttop: 46px;\r\n}\r\n\r\n.nuestra\r\n{\r\n\toverflow: hidden;\r\n\tfont-size: 12px;\r\n\twidth: 510px;\r\n\tcolor: #666666;\r\n\tfont-weight: bold;\r\n}\r\n.nuestra .titulo\r\n{\r\n\tcolor: #92c846;\r\n\tfont-size: 15px;\r\n\tmargin: 16px 0 0 9px;\r\n}\r\n.nuestra .titulo b\r\n{\r\n\tcolor: #92C846;\r\n\tfont-size: 21px;\r\n}\r\n.nuestra .tex1\r\n{\r\n\tfont-weight: bold;\r\n\tmargin: 8px 0 0 8px;\r\n}\r\n.nuestra .tex2\r\n{\r\n\tfont-size: 16px;\r\n\tmargin: 17px 0 0 7px;\r\n\tcolor: #92C846;\r\n}\r\n.nuestra .tex3\r\n{\r\n\tmargin: 0 0 0 7px;\r\n}\r\n.nuestra .tex3 b\r\n{\r\n\tcolor: #015C7A;\r\n}\r\n.nuestra .tex4\r\n{\r\n\tmargin: 21px 0 0 6px;\r\n\tcolor: #666666;\r\n}\r\n.nuestra .tex4 a\r\n{\r\n\tcolor: #1f79d2;\r\n}\r\n.nuestra .tex5\r\n{\r\n\tmargin: 17px 0 0 7px;\r\n\tcolor: #666666;\r\n}\r\n.nuestra .tex5 a\r\n{\r\n\tcolor: #1f79d2;\r\n}\r\n.nuestra .tex6\r\n{\r\n\tcolor: #015C7A;\r\n\tmargin: 33px 0 0 4px;\r\n}\r\n.nuestra .tex6 b\r\n{\r\n\tcolor: #92C846;\r\n\tfont-size: 18px;\r\n}\r\n.nuestra .disfrutar ul\r\n{\r\n\tlist-style: none;\r\n\tcolor: #666666;\r\n}\r\n.disfrutar .casillero\r\n{\r\n\tmargin: 19px 0 0 0;\r\n}\r\n.disfrutar .tendra\r\n{\r\n\tmargin: 18px 0 0 0;\r\n}\r\n.disfrutar .caso\r\n{\r\n\tmargin: 18px 0 0 0;\r\n}\r\n.disfrutar .forma\r\n{\r\n\tmargin: 19px 0 0;\r\n}\r\n.disfrutar .cuenta\r\n{\r\n\tmargin: 18px 0 0;\r\n}\r\n.disfrutar .brindamos\r\n{\r\n\tmargin: 18px 0 0;\r\n}\r\n.disfrutar b\r\n{\r\n\tcolor: #ff6600;\r\n}\r\n.coyright2\r\n{\r\n\tborder-top: solid 1px;\r\n\tcolor: #EB5F0A;\r\n\tmargin: 18px 0 0;\r\n\twidth: 723px;\r\n\theight: 19px;\r\n}\r\n.coyright2 b\r\n{\r\n\tcolor: #858585;\r\n\tfont-size: 11px;\r\n\theight: 13px;\r\n\twidth: 315px;\r\n\tleft: 243px;\r\n\tposition: relative;\r\n\ttop: 3px;\r\n}\r\n\r\n\r\n/*crbox-Contactenos*/\r\n\r\n.info3\r\n{\r\n\tbackground: url(Images/three.png) no-repeat;\r\n\theight: 111px;\r\n\twidth: 178px;\r\n\tmargin: 21px 0 0 6px;\r\n}\r\n.aerea\r\n{\r\n\tbackground: url(Images/aerea.png) no-repeat;\r\n\theight: 54px;\r\n\twidth: 179px;\r\n\tmargin: 16px 0 0 2px;\r\n}\r\n.aerea a\r\n{\r\n}\r\n.maritima\r\n{\r\n\tbackground: url(Images/maritima.png) no-repeat;\r\n\theight: 53px;\r\n\twidth: 180px;\r\n\tmargin: 18px 0 0 2px;\r\n}\r\n.info3 a\r\n{\r\n\ttext-decoration: none;\r\n\tcolor: #FFFFFF;\r\n\tfont-size: 12px;\r\n\tmargin: 78px 0 0 63px;\r\n\tfloat: left;\r\n\tfont-weight: bold;\r\n}\r\n\r\n.contactenos\r\n{\r\n\tmargin: 15px 0 0 7px;\r\n\twidth: 528px;\r\n}\r\n.contactenos h2\r\n{\r\n\tcolor: #92c846;\r\n\tfont-size: 16px;\r\n\twidth: 526px;\r\n}\r\n.contactenos h2 b\r\n{\r\n\tfont-size: 22px;\r\n}\r\n.contactenos .tex1\r\n{\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\tcolor: #707070;\r\n\tmargin: 23px 0 0 3px;\r\n}\r\n.contactenos .tex1 b\r\n{\r\n\tcolor: #015c7a;\r\n}\r\n.contactenos .tex2 b\r\n{\r\n\tcolor: #92c846;\r\n\tfont-size: 18px;\r\n}\r\n.contactenos .tex2\r\n{\r\n\tcolor: #015c7a;\r\n\tfont-size: 15px;\r\n\tfont-weight: bold;\r\n\tmargin: 13px 0 0 2px;\r\n\twidth: 258px;\r\n}\r\n.contactenos .hombre\r\n{\r\n\tbackground: url(Images/hombre.png) no-repeat;\r\n\tfloat: right;\r\n\theight: 263px;\r\n\tmargin: 3px 77px;\r\n\twidth: 143px;\r\n}\r\n.contactenos .horario\r\n{\r\n\tcolor: #666666;\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\tmargin: 19px 0 0 5px;\r\n\twidth: 258px;\r\n}\r\n.contactenos .telefono\r\n{\r\n\tcolor: #666666;\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\tmargin: 0 0 0 4px;\r\n\twidth: 258px;\r\n}\r\n.contactenos .consulta\r\n{\r\n\tcolor: #666666;\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\tmargin: 18px 0 0 5px;\r\n\twidth: 258px;\r\n}\r\n.contactenos .direccion\r\n{\r\n\tcolor: #666666;\r\n\tfont-size: 12px;\r\n\tfont-weight: bold;\r\n\tmargin: 2px 0 0 5px;\r\n\twidth: 258px;\r\n}\r\n.contactenos .susconsultas\r\n{\r\n\tcolor: #92c846;\r\n\tfont-size: 18px;\r\n\tmargin: 39px 0 0 3px;\r\n}\r\n.contactenos .susconsultas span\r\n{\r\n\tdisplay: block;\r\n\tmargin: 0 0 6px;\r\n}\r\n.contactenos .susconsultas b\r\n{\r\n\tmargin: 0 0 0 3px;\r\n\tfont-size: 15px;\r\n\tcolor: #666666;\r\n}\r\n.formconsul .verifica\r\n{\r\n\theight: 127px;\r\n\tleft: 357px;\r\n\tposition: absolute;\r\n\ttop: 170px;\r\n\twidth: 314px;\r\n}\r\n\r\n/* CALCULADORA */\r\n\r\n.calculadora div.calculadora\r\n{\r\n\tposition: relative;\r\n\tmargin: 0;\r\n\tpadding: 35px 0 0;\r\n}\r\n.calculadora div.calculadora li\r\n{\r\n\tlist-style-type: none;\r\n\tmargin: 0 0 10px;\r\n}\r\n.calculadora div.calculadora .arancel\r\n{\r\n\tposition: absolute;\r\n\ttop: 35px;\r\n\tleft: 115px;\r\n}\r\n.calculadora div.calculadora .arancel select\r\n{\r\n\twidth: 307px;\r\n}\r\n.calculadora div.calculadora .dimensiones\r\n{\r\n}\r\n.calculadora div.calculadora .dimensiones ul\r\n{\r\n\tposition: absolute;\r\n\ttop: 75px;\r\n\tleft: 115px;\r\n}\r\n.calculadora div.calculadora .dimensiones ul li\r\n{\r\n\tcolor: green;\r\n\tfloat: left;\r\n\tmargin: 0 10px 0 0;\r\n}\r\n.calculadora div.calculadora .dimensiones ul li input\r\n{\r\n}\r\n.calculadora div.calculadora .dimensiones .params\r\n{\r\n\tposition: absolute;\r\n\ttop: 102px;\r\n\tleft: 115px;\r\n}\r\n.calculadora div.calculadora .dimensiones .params li\r\n{\r\n\tcolor: #A24C50;\r\n\tdisplay: inline;\r\n}\r\n.calculadora div.calculadora .dimensiones .peso li\r\n{\r\n}\r\n.calculadora div.calculadora .peso\r\n{\r\n\tcolor: green;\r\n}\r\n.calculadora div.calculadora .peso ul\r\n{\r\n\tposition: absolute;\r\n\ttop: 140px;\r\n\tleft: 115px;\r\n}\r\n.calculadora div.calculadora .peso ul li\r\n{\r\n\tfloat: left;\r\n\tmargin: 0 10px 0 0;\r\n}\r\n.calculadora div.calculadora .peso .calcFields\r\n{\r\n\tposition: absolute;\r\n\ttop: 140px;\r\n\tleft: 240px;\r\n}\r\n.calculadora div.calculadora .monto\r\n{\r\n}\r\n.calculadora div.calculadora .monto .calcFields\r\n{\r\n\tposition: absolute;\r\n\tleft: 119px;\r\n\ttop: 192px;\r\n\twidth: 78px;\r\n}\r\n.calculadora div.calculadora .casillero\r\n{\r\n\tclear: both;\r\n\tposition: absolute;\r\n\ttop: 242px;\r\n\tleft: 108px;\r\n}\r\n#calculateCost\r\n{\r\n\tposition: absolute;\r\n\ttop: 242px;\r\n\tleft: 336px;\r\n\twidth: 75px;\r\n}\r\n#formCalculadora\r\n{\r\n\tpadding: 35px;\r\n}\r\n.desgloce span\r\n{\r\n\tcolor: SteelBlue;\r\n\tdisplay: block;\r\n\tfloat: left;\r\n\tfont-size: 18px;\r\n\tfont-weight: bold;\r\n\tmargin: 74px 0 0;\r\n\twidth: 80px;\r\n\ttext-align: center;\r\n}\r\n.desgloce span.flete\r\n{\r\