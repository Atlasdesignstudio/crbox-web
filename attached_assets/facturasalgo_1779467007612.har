controlname).hide();\r\n                }\r\n                $(\"#volumetricheader\").hide();\r\n            }\r\n        }\r\n        function chkTotalVolumeChange() {\r\n            var checkeado = $(\"#chkTotalVolume\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkTotalVolume\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#volumenrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#volumenheader\").show();\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#volumenrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#volumenheader\").hide();\r\n            }\r\n        }\r\n\r\n        function chkNotesChange() {\r\n            var checkeado = $(\"#chkNotes\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkNotes\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#notesrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#notesheader\").show();\r\n\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#notesrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#notesheader\").hide();\r\n            }\r\n        }\r\n\r\n        function chkCreatedByChange() {\r\n            var checkeado = $(\"#chkCreatedBy\").is(\":checked\");\r\n            $(\"#checksdiv\").load(\"/WareHouseReceipt/SaveSessionCheck\", { \"controlname\": \"chkCreatedBy\", \"ischecked\": checkeado });\r\n            var count1 = $(\"#listcount\").val();\r\n            if (checkeado) {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#createdbyrow\" + (i + 1);\r\n                    $(controlname).show();\r\n                }\r\n                $(\"#createdbyheader\").show();\r\n\r\n            }\r\n            else {\r\n                for (var i = 0; i < count1; i++) {\r\n                    var controlname = \"#createdbyrow\" + (i + 1);\r\n                    $(controlname).hide();\r\n                }\r\n                $(\"#createdbyheader\").hide();\r\n            }\r\n        }\r\n        //Guardar Aereo\r\n        function GuardarAereo() {\r\n            $(\"#divmensaje\").html(\"<b> Guardando los recibos seleccionados...</b>\");\r\n            $(\"#divmensaje\").load(\"/WareHouseReceipt/SaveAereo\", { \"warehousenormal\": $(\"#WareHouseReceipts\").val(), \"warehouseboxing\": $(\"#BoxingWareHouseReceipts\").val() });\r\n        }\r\n\r\n        function GuardarImpreso(checkbox) {\r\n            GuardarImpresoConsolidado($(checkbox).attr(\"id\").split(\"_\")[0], $(checkbox).prop(\"checked\"), true, checkbox);\r\n        }\r\n\r\n        function GuardarConsolidado(checkbox) {\r\n            GuardarImpresoConsolidado($(checkbox).attr(\"id\").split(\"_\")[0], $(checkbox).prop(\"checked\"), false, checkbox);\r\n        }\r\n\r\n        function GuardarImpresoConsolidado(idWarehouseReceipt, isChecked, isImpreso, checkbox) {\r\n            $.ajax({\r\n                url: \"/WareHouseReceipt/\" + (isImpreso ? \"GuardarImpreso\" : \"GuardarConsolidado\"),\r\n                data: {\r\n                    \"idWarehouseReceipt\": idWarehouseReceipt.toString(),\r\n                    \"isChecked\": isChecked\r\n                },\r\n                success: function (result) {\r\n                    if (!result.saved) {\r\n                        $(checkbox).prop(\"checked\", !isChecked);\r\n                    }\r\n                    console.log(\"Guardado - Impreso/Consolidado\");\r\n                },\r\n                error: function () {\r\n                    console.log(\"Error - Impreso/Consolidado\");\r\n                }\r\n            });\r\n        }\r\n\r\n        function QuitarEmisionEcont(checkbox) {\r\n            QuitarImprimidoEtiquetaNormal($(checkbox).attr(\"id\"), $(checkbox).prop(\"checked\"), true, checkbox);\r\n        }\r\n\r\n        function QuitarEmisionNormal(checkbox) {\r\n            QuitarImprimidoEtiquetaNormal($(checkbox).attr(\"id\"), $(checkbox).prop(\"checked\"), false, checkbox);\r\n        }\r\n\r\n        function QuitarImprimidoEtiquetaNormal(idWarehouseReceipt, isChecked, isTipoEtiqueta, checkbox) {\r\n            $.ajax({\r\n                url: \"/WareHouseReceipt/\" + (isTipoEtiqueta ? \"CambiarCheckEmisionEcont\" : \"CambiarCheckEmisionNormal\"),\r\n                data: {\r\n                    \"idWarehouseReceipt\": idWarehouseReceipt.toString(),\r\n                    \"isChecked\": isChecked\r\n                },\r\n                success: function (result) {\r\n                    if (!result.saved) {\r\n                        $(checkbox).prop(\"checked\", !isChecked);\r\n                    }\r\n                    console.log(\"Cambio realizado - Normal/Econt\");\r\n                },\r\n                error: function () {\r\n                    console.log(\"Error - Normal/Econt\");\r\n                }\r\n            });\r\n        }\r\n\r\n        function SelectChanged(that) {\r\n            $(\"#descripcionFactura\").val($(\"#descripcionFactura\").val() + \" \" + $(that).val());\r\n        }\r\n\r\n        function openUploadInvoiceForm(warehouseReceiptId) {\r\n            var purchaseBillEditor = null;\r\n\r\n            $(\"#textAreaPlace\").html(\"\").html(\"<textarea id='ClientInvoiceText' cols='4' name='ClientInvoiceText'></textarea>\");\r\n            $(\"#numberRecibo\").text(\"Recibo #: \" + warehouseReceiptId);\r\n            $(\"#WRId\").val(warehouseReceiptId);\r\n            $('#montoFactura').mask(\"#,##0.00\", { reverse: true });\r\n            $(\"#descripcionFactura\").val(\"\");\r\n\r\n            $(\"#uploadPurchaseBill\").dialog({\r\n                autoOpen: false,\r\n                height: 550,\r\n                width: 622,\r\n                modal: true,\r\n                resizable: true,\r\n                title: \"Subir Factura\",\r\n                closeOnEscape: true,\r\n                hide: {\r\n                    effect: \"highlight\",\r\n                    duration: 1000\r\n                }\r\n            });\r\n\r\n            purchaseBillEditor = new TINY.editor.edit('editor', {\r\n                id: 'ClientInvoiceText',\r\n                width: 584,\r\n                height: 175,\r\n                cssclass: 'tinyeditor',\r\n                controlclass: 'tinyeditor-control',\r\n                rowclass: 'tinyeditor-header',\r\n                dividerclass: 'tinyeditor-divider',\r\n                controls: ['bold', 'italic', 'underline', 'strikethrough', '|', 'subscript', 'superscript', '|',\r\n                    'orderedlist', 'unorderedlist', '|', 'outdent', 'indent', '|', 'leftalign',\r\n                    'centeralign', 'rightalign', 'blockjustify', '|', 'unformat', '|', 'undo', 'redo', 'n',\r\n                    'font', 'size', 'style', '|', 'image', 'hr', 'link', 'unlink', '|', 'print'],\r\n                footer: true,\r\n                fonts: ['Verdana', 'Arial', 'Georgia', 'Trebuchet MS'],\r\n                xhtml: true,\r\n                //cssfile: 'custom.css',\r\n                encoding: \"xml\",\r\n                bodyid: 'editor',\r\n                footerclass: 'tinyeditor-footer',\r\n                toggle: { text: 'source', activetext: 'wysiwyg', cssclass: 'toggle' },\r\n                //resize: { cssclass: 'resize' }\r\n            });\r\n\r\n            //signal editor to sync content on rich text editor\r\n            $('#frmPurchaseBill').submit(function () {\r\n\r\n                //purchaseBillEditor.post(); //standard way to pass editor content to textarea, it implies making a POST ro refresh contents\r\n\r\n                //to avoid making a post, we will get the iframe contents with jquery and pass it to the textarea\r\n                var richTextContent = $(\".tinyeditor iframe\").contents().find(\"body\").html();\r\n\r\n                //to avoid XSS attack alert, html text has to be encoded first. \r\n                //we just simply replace angular tags and ampersands\r\n                var encodedRichTextContent = richTextContent.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');\r\n                $(\"#ClientInvoiceText\").val(encodedRichTextContent);\r\n\r\n                return true;\r\n            });\r\n\r\n            $(\"#frmPurchaseBill\").validate({\r\n                rules: {\r\n                    numFactura: \"required\",\r\n                    montoFactura: {\r\n                        greaterThan: [0],\r\n                        required: true\r\n                    },\r\n                    descripcionFactura: \"required\",\r\n                    ClientInvoiceFile: {\r\n                        required: false,\r\n                        extension: \"png|jpe?g|gif|pdf\"\r\n                    }\r\n                },\r\n                messages: {\r\n                    numFactura: \"Por favor ingrese el número de factura\",\r\n                    montoFactura: {\r\n                        required: \"Por favor ingrese el monto de la factura\"\r\n                    },\r\n                    descripcionFactura: \"Por favor ingrese la descripción de la factura\",\r\n                    ClientInvoiceFile: {\r\n                        extension: \"Solo se permiten imagenes o archivos pdf\"\r\n                    }\r\n                }\r\n            });\r\n\r\n            $.validator.addMethod(\"greaterThan\", function (value, element, params) {\r\n                var currentValue = isNaN($(\"#\" + element.id).cleanVal()) ? undefined : parseFloat($(\"#\" + element.id).cleanVal());\r\n                return this.optional(element) || currentValue > params[0];\r\n            }, $.validator.format(\"Debe ingresar un valor mayor que {0}.\"));\r\n\r\n            $.validator.addMethod(\"extension\", function (value, element, param) {\r\n                param = typeof param === \"string\" ? param.replace(/,/g, \"|\") : \"png|jpe?g|gif|pdf\";\r\n                return this.optional(element) || value.match(new RegExp(\"\\\\.(\" + param + \")$\", \"i\"));\r\n            }, $.validator.format(\"Solo se permiten imagenes o archivos pdf\"));\r\n\r\n            //open dialog\r\n            $(\"#uploadPurchaseBill\").dialog(\"open\");\r\n        }\r\n\r\n        function SelectChangedEdit(that) {\r\n            $(\"#descripcionFacturaEdit\").val($(\"#descripcionFacturaEdit\").val() + \" \" + $(that).val());\r\n        }\r\n\r\n        function ShowPurchaseBill(warehouseReceiptId) {\r\n            var purchaseBillEditor = null;\r\n            $(\"#uploadFormWrapper\").dialog({\r\n                autoOpen: false,\r\n                height: $(window).height() - 50,\r\n                width: 722,\r\n                modal: true,\r\n                title: \"Factura Enviada, Recibo #\" + warehouseReceiptId,\r\n                closeOnEscape: true,\r\n                hide: {\r\n                    effect: \"highlight\",\r\n                    duration: 1000\r\n                }\r\n            });\r\n\r\n            $.ajax({\r\n                type: \"GET\",\r\n                url: \"/WareHouseReceipt/ShowAdminPurchaseBill\",\r\n                data: \"warehouseReceiptId=\" + warehouseReceiptId,\r\n                success: function (data) {\r\n                    if (data != null) {\r\n                        if (data != \"\") {\r\n\r\n                            $(\"#uploadFormWrapper\").html(data);\r\n\r\n                            //open dialog\r\n                            $(\"#uploadFormWrapper\").dialog(\"open\");\r\n                            $(\"#uploadAccordionEdit\").accordion({ header: \"h2\", collapsible: true });\r\n                            $(\"#textAreaPlaceEdit\").html(\"\").html(\"<textarea id='ClientInvoiceTextEdit' cols='4' name='ClientInvoiceTextEdit'>\" + $(\"#FileTextContentEdit\").val() + \"</textarea>\");\r\n                            $(\"#WRIdEdit\").val(warehouseReceiptId);\r\n                            $('#montoFacturaEdit').mask(\"#,##0.00\", { reverse: true });\r\n                            purchaseBillEditor = new TINY.editor.edit('editor', {\r\n                                id: 'ClientInvoiceTextEdit',\r\n                                width: 584,\r\n                                height: 175,\r\n                                cssclass: 'tinyeditor',\r\n                                controlclass: 'tinyeditor-control',\r\n                                rowclass: 'tinyeditor-header',\r\n                                dividerclass: 'tinyeditor-divider',\r\n                                controls: ['bold', 'italic', 'underline', 'strikethrough', '|', 'subscript', 'superscript', '|',\r\n                                    'orderedlist', 'unorderedlist', '|', 'outdent', 'indent', '|', 'leftalign',\r\n                                    'centeralign', 'rightalign', 'blockjustify', '|', 'unformat', '|', 'undo', 'redo', 'n',\r\n                                    'font', 'size', 'style', '|', 'image', 'hr', 'link', 'unlink', '|', 'print'],\r\n                                footer: true,\r\n                                fonts: ['Verdana', 'Arial', 'Georgia', 'Trebuchet MS'],\r\n                                xhtml: true,\r\n                                //cssfile: 'custom.css',\r\n                                encoding: \"xml\",\r\n                                bodyid: 'editor',\r\n                                footerclass: 'tinyeditor-footer',\r\n                                toggle: { text: 'source', activetext: 'wysiwyg', cssclass: 'toggle' },\r\n                                //resize: { cssclass: 'resize' }\r\n                            });\r\n\r\n                            $(\"#frmPurchaseBillEdit\").validate({\r\n                                rules: {\r\n                                    numFacturaEdit: \"required\",\r\n                                    montoFacturaEdit: {\r\n                                        greaterThan: [0],\r\n                                        required: true\r\n                                    },\r\n                                    descripcionFacturaEdit: \"required\",\r\n                                    ClientInvoiceFile: {\r\n                                        required: false,\r\n                                        extension: \"png|jpe?g|gif|pdf\"\r\n                                    }\r\n                                },\r\n                                messages: {\r\n                                    numFacturaEdit: \"Por favor ingrese el número de factura\",\r\n                                    montoFacturaEdit: {\r\n                                        required: \"Por favor ingrese el monto de la factura\"\r\n                                    },\r\n                                    descripcionFacturaEdit: \"Por favor ingrese la descripción de la factura\",\r\n                                    ClientInvoiceFile: {\r\n                                        extension: \"Solo se permiten imagenes o archivos pdf\"\r\n                                    }\r\n                                }\r\n                            });\r\n\r\n                            $.validator.addMethod(\"greaterThan\", function (value, element, params) {\r\n                                var currentValue = isNaN($(\"#\" + element.id).cleanVal()) ? undefined : parseFloat($(\"#\" + element.id).cleanVal());\r\n                                return this.optional(element) || currentValue > params[0];\r\n                            }, $.validator.format(\"Debe ingresar un valor mayor que {0}.\"));\r\n\r\n                            $.validator.addMethod(\"extension\", function (value, element, param) {\r\n                                param = typeof param === \"string\" ? param.replace(/,/g, \"|\") : \"png|jpe?g|gif|pdf\";\r\n                                return this.optional(element) || value.match(new RegExp(\"\\\\.(\" + param + \")$\", \"i\"));\r\n                            }, $.validator.format(\"Solo se permiten imagenes o archivos pdf\"));\r\n\r\n                            //signal editor to sync content on rich text editor\r\n                            $('#frmPurchaseBillEdit').submit(function () {\r\n\r\n                                purchaseBillEditor.post(); //standard way to pass editor content to textarea, it implies making a POST ro refresh contents\r\n\r\n                                //to avoid making a post, we will get the iframe contents with jquery and pass it to the textarea\r\n                                var richTextContent = $(\".tinyeditor iframe\").contents().find(\"body\").html();\r\n\r\n                                //to avoid XSS attack alert, html text has to be encoded first. \r\n                                //we just simply replace angular tags and ampersands\r\n                                var encodedRichTextContent = richTextContent.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');\r\n                                $(\"#ClientInvoiceTextEdit\").val(encodedRichTextContent);\r\n\r\n                                return true;\r\n                            });\r\n\r\n                        }\r\n                    }\r\n                }\r\n            });\r\n        }\r\n\r\n        function toggleEmision() {\r\n            let popup = document.getElementById('popupEmision');\r\n            popup.classList.toggle('active');\r\n        }\r\n        function TtoggleEmision() {\r\n            let popup = document.getElementById('PpopupEmision');\r\n            popup.classList.toggle('active');\r\n        }\r\n\r\n        function toggleEmision2() {\r\n            let popup = document.getElementById('popupEmision2');\r\n            popup.classList.toggle('active');\r\n        }\r\n\r\n        function TtoggleEmision2() {\r\n            let popup = document.getElementById('PpopupEmision2');\r\n            popup.classList.toggle('active');\r\n        }\r\n\r\n        $('#btnopciones').on(\"click\", function () {\r\n            Swal.fire({\r\n                title: 'Por favor elija una opción.',\r\n                showCancelButton: true,\r\n                confirmButtonText: 'Imprimir etiquetas no emitidas',\r\n            }).then((result) => {\r\n                if (result.isConfirmed) {\r\n                    toggleEmision();\r\n                } else if (result.isDenied) {\r\n                }\r\n            })\r\n        });\r\n\r\n        $('#btnopciones2').on(\"click\", function () {\r\n            Swal.fire({\r\n                title: 'Por favor elija una opción.',\r\n                showCancelButton: true,\r\n                confirmButtonText: 'Imprimir etiquetas no impresas',\r\n            }).then((result) => {\r\n                if (result.isConfirmed) {\r\n                    toggleEmision2();\r\n                } else if (result.isDenied) {\r\n                }\r\n            })\r\n        });\r\n\r\n    </script>\r\n\r\n\r\n\r\n\r\n    \r\n    \r\n</body>\r\n</html>"
